{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    {jhn_stdlib, "~> 5.11"}
]}.

{project_plugins, [
    erlfmt,
    rebar3_lint,
    rebar3_hank,
    rebar3_ex_doc,
    rebar3_audit,
    {rebar3_sbom,
        {git, "https://github.com/Taure/rebar3_sbom.git", {branch, "feat/include-otp-components"}}},
    rebar3_mutate
]}.

{erlfmt, [write]}.

{hank, [
    {ignore, [
        "apps/nova_audit/src/nova_audit_adapter.erl",
        "apps/*/test/**"
    ]}
]}.

{xref_ignores, [
    {kura_repo, insert, 3},
    {kura_query, query, 4},
    {pgo, query, 3},
    {shigoto, enqueue, 1},
    {telemetry, execute, 3},
    {nova_audit, log, 2},
    {nova_audit, log_async, 2},
    {nova_audit, query, 2},
    {nova_audit, query, 3},
    {nova_audit_event, schema_version, 0},
    {nova_audit_registry, start_link, 0},
    {nova_audit_registry, list, 0},
    {nova_audit_registry, unregister, 1},
    {nova_audit_sup, start_log, 2},
    {nova_audit_sup, stop_log, 1},
    {nova_audit_kura, hardening_sql, 0},
    {nova_audit_kura, hardening_sql, 1},
    {nova_audit_kura, schema_sql, 0},
    {nova_audit_pgo, hardening_sql, 0},
    {nova_audit_pgo, hardening_sql, 1},
    {nova_audit_pgo, schema_sql, 0}
]}.

{dialyzer, [
    {warnings, [error_handling, unmatched_returns]}
]}.

{ex_doc, [
    {extras, [
        {"README.md", #{title => <<"Overview">>}},
        {"guides/getting-started.md", #{title => <<"Getting Started">>}},
        {"guides/walkthrough.md", #{title => <<"Walkthrough: Audit a Nova App">>}},
        {"guides/adapters.md", #{title => <<"Adapters">>}},
        {"guides/compliance.md", #{title => <<"Compliance Notes">>}},
        {"guides/telemetry.md", #{title => <<"Telemetry">>}},
        {"guides/runbook.md", #{title => <<"Operations Runbook">>}},
        {"guides/anti-patterns.md", #{title => <<"Anti-patterns">>}}
    ]},
    {main, <<"readme">>},
    {source_url, <<"https://github.com/novaframework/nova_audit">>},
    {groups_for_modules, [
        {<<"Core API">>, [nova_audit]},
        {<<"Behaviours">>, [nova_audit_adapter]},
        {<<"Adapters">>, [nova_audit_log, nova_audit_kura, nova_audit_pgo]},
        {<<"Internal">>, [nova_audit_registry, nova_audit_worker, nova_audit_event]}
    ]}
]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]},
        {deps, [
            {meck, "~> 0.9"},
            {telemetry, "~> 1.3"}
        ]}
    ]}
]}.
